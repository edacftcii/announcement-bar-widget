@model Nop.Plugin.Widgets.AnnouncementBar.Models.AnnouncementBarModel

@if (Model?.Items != null && Model.Items.Any())
{
    <style>
        .announcement-bar-wrapper {
            width: 100%;
            overflow: hidden;
            background: #111111;
            color: #ffffff;
            height: 56px;
            line-height: 56px;
            position: relative;
            z-index: 9999;
            box-sizing: border-box;
            white-space: nowrap;
            margin-bottom: 15px;
            border-radius: 0;
            font-size: 16px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .announcement-bar-track {
            display: inline-block;
            white-space: nowrap;
            padding-left: 100%;
            animation: announcement-bar-slide 18s linear infinite;
            vertical-align: middle;
        }

        .announcement-bar-item {
            display: inline-block;
            margin-right: 18px;
        }

        .announcement-bar-separator {
            display: inline-block;
            color: #ffffff;
            margin-right: 18px;
        }

        @@keyframes announcement-bar-slide {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-100%);
            }
        }
    </style>

    <div class="announcement-bar-wrapper">
        <div class="announcement-bar-track">
            @for (var i = 0; i < Model.Items.Count; i++)
            {
                <span class="announcement-bar-item" style="color:@Model.Items[i].Color;">
                    @Model.Items[i].Text
                </span>

                @if (i < Model.Items.Count - 1)
                {
                    <span class="announcement-bar-separator">✦</span>
                }
            }
        </div>
    </div>
}