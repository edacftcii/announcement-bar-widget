@model Nop.Plugin.Widgets.AnnouncementBar.Models.AnnouncementItemModel
@inject Nop.Services.Localization.ILocalizationService localizationService

@{
    Layout = "_AdminLayout";

    var pageTitleCreate = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.PageTitle.Create");
    var pageTitleEdit = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.PageTitle.Edit");
    var cardInfoTitle = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Card.Info");

    var fieldText = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Fields.Text");
    var fieldColor = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Fields.Color");
    var fieldDisplayOrder = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Fields.DisplayOrder");
    var fieldIsActive = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Fields.IsActive");

    var saveText = await localizationService.GetResourceAsync("Admin.Common.Save");
    var backToListText = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Button.BackToList");

    ViewBag.PageTitle = Model.Id > 0 ? pageTitleEdit : pageTitleCreate;

    var formAction = Model.Id > 0
        ? Url.Action("EditPost", "AnnouncementBar", new { area = "Admin" })
        : Url.Action("CreatePost", "AnnouncementBar", new { area = "Admin" });
}

<form action="@formAction" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="content-header clearfix">
        <h1 class="float-left">
            @(Model.Id > 0 ? pageTitleEdit : pageTitleCreate)
        </h1>
        <div class="float-right">
            <button type="submit" class="btn btn-primary">
                <i class="far fa-save"></i>
                @saveText
            </button>
            <a href="@Url.Action("Configure", "AnnouncementBar", new { area = "Admin" })" class="btn btn-default">
                <i class="fas fa-arrow-left"></i>
                @backToListText
            </a>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <nop-cards id="announcement-bar-item-cards">
                <nop-card asp-name="announcement-bar-item-info"
                          asp-icon="fas fa-info-circle"
                          asp-title="@cardInfoTitle"
                          asp-hide-block-attribute-name="AnnouncementBarItemInfo.Hide"
                          asp-hide="false"
                          asp-advanced="false">

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label for="Text">@fieldText</label>
                        </div>
                        <div class="col-md-9">
                            <input id="Text" name="Text" class="form-control" value="@Model.Text" />
                            <span asp-validation-for="Text"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label for="Color">@fieldColor</label>
                        </div>
                        <div class="col-md-9">
                            <input id="Color"
                                   name="Color"
                                   class="form-control"
                                   value="@Model.Color"
                                   placeholder="#28a745" />
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label for="DisplayOrder">@fieldDisplayOrder</label>
                        </div>
                        <div class="col-md-9">
                            <input id="DisplayOrder"
                                   name="DisplayOrder"
                                   type="number"
                                   class="form-control"
                                   value="@Model.DisplayOrder" />
                            <span asp-validation-for="DisplayOrder"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label>@fieldIsActive</label>
                        </div>
                        <div class="col-md-9">
                            <div style="padding-top: 8px;">
                                @Html.CheckBoxFor(m => m.IsActive)
                            </div>
                        </div>
                    </div>

                </nop-card>
            </nop-cards>
        </div>
    </section>
</form>