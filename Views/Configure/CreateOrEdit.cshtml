@model Nop.Plugin.Widgets.AnnouncementBar.Models.AnnouncementItemModel
@inject Nop.Services.Localization.ILocalizationService localizationService

@{
    Layout = "_AdminLayout";

    var pageTitleCreate = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.PageTitle.Create");
    var pageTitleEdit = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.PageTitle.Edit");

    var saveText = await localizationService.GetResourceAsync("Admin.Common.Save");
    var backToListText = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Button.BackToList");

    var textLabel = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Fields.Text");
    var colorLabel = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Fields.Color");
    var linkUrlLabel = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Fields.LinkUrl");
    var displayOrderLabel = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Fields.DisplayOrder");
    var isActiveLabel = await localizationService.GetResourceAsync("Plugins.Widgets.AnnouncementBar.Fields.IsActive");

    ViewBag.PageTitle = Model.Id > 0 ? pageTitleEdit : pageTitleCreate;

    var formAction = Model.Id > 0
        ? Url.Action("EditPost", "AnnouncementBar", new { area = "Admin" })
        : Url.Action("CreatePost", "AnnouncementBar", new { area = "Admin" });
}

<form action="@formAction" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="content-header clearfix">
        <h1 class="float-left">
            @(Model.Id > 0 ? pageTitleEdit : pageTitleCreate)
        </h1>
        <div class="float-right">
            <button type="submit" class="btn btn-primary">
                <i class="far fa-save"></i>
                @saveText
            </button>
            <a href="@Url.Action("Manage", "AnnouncementBar", new { area = "Admin" })" class="btn btn-default">
                <i class="fas fa-arrow-left"></i>
                @backToListText
            </a>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div class="card card-default">
                <div class="card-body">

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label for="Text">@textLabel</label>
                        </div>
                        <div class="col-md-9">
                            <input id="Text" name="Text" class="form-control" value="@Model.Text" />
                            <span asp-validation-for="Text"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label for="Color">@colorLabel</label>
                        </div>
                        <div class="col-md-9">
                            <input id="Color" name="Color" class="form-control" value="@Model.Color" placeholder="#ffffff" />
                            <span asp-validation-for="Color"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label for="LinkUrl">@linkUrlLabel</label>
                        </div>
                        <div class="col-md-9">
                            <input id="LinkUrl" name="LinkUrl" class="form-control" value="@Model.LinkUrl" placeholder="https://example.com" />
                            <span asp-validation-for="LinkUrl"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label for="DisplayOrder">@displayOrderLabel</label>
                        </div>
                        <div class="col-md-9">
                            <input id="DisplayOrder" name="DisplayOrder" type="number" class="form-control" value="@Model.DisplayOrder" />
                            <span asp-validation-for="DisplayOrder"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <label for="IsActive">@isActiveLabel</label>
                        </div>
                        <div class="col-md-9">
                            <input id="IsActive" name="IsActive" type="checkbox" value="true" @(Model.IsActive ? "checked" : "") />
                            <input name="IsActive" type="hidden" value="false" />
                            <span asp-validation-for="IsActive"></span>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</form>