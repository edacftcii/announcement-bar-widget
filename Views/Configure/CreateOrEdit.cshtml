@model Nop.Plugin.Widgets.AnnouncementBar.Models.AnnouncementItemModel

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = Model.Id > 0 ? "Duyuru Düzenle" : "Yeni Duyuru";
    var formAction = Model.Id > 0 ? "/Admin/AnnouncementBar/EditPost" : "/Admin/AnnouncementBar/CreatePost";
}

<form action="@formAction" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="content-header clearfix">
        <h1 class="float-left">
            @(Model.Id > 0 ? "Duyuru Düzenle" : "Yeni Duyuru")
        </h1>
        <div class="float-right">
            <button type="submit" class="btn btn-primary">
                Kaydet
            </button>
            <a href="/Admin/AnnouncementBar/Configure" class="btn btn-secondary">
                Geri Dön
            </a>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div class="card card-default">
                <div class="card-body">

                    <div class="form-group">
                        <label for="Text">Text</label>
                        <input id="Text" name="Text" class="form-control" value="@Model.Text" />
                    </div>

                    <div class="form-group">
                        <label for="Color">Color</label>
                        <input id="Color" name="Color" class="form-control" value="@Model.Color" placeholder="#28a745" />
                    </div>

                    <div class="form-group">
                        <label for="DisplayOrder">Display Order</label>
                        <input id="DisplayOrder" name="DisplayOrder" type="number" class="form-control" value="@Model.DisplayOrder" />
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input type="hidden" name="IsActive" value="false" />
                            <input id="IsActive" name="IsActive" type="checkbox" class="form-check-input" value="true" @(Model.IsActive ? "checked=\"checked\"" : "") />
                            <label for="IsActive" class="form-check-label">Is Active</label>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</form>